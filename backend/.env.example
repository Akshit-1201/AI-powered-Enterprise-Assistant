# Copy to .env and fill in. .env is gitignored.

# Required for /ask (LLM reasoning + tool-calling). /health works without it.
OPENAI_API_KEY=sk-your-key-here

# Auth — set a strong random JWT_SECRET for anything beyond local dev.
# JWT_SECRET=change-me-to-a-long-random-string
# JWT_EXPIRE_MINUTES=60

# Optional overrides (defaults shown).
# CHAT_MODEL=gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-small
# CHAT_TEMPERATURE=0.0       # set to 1 for reasoning models that reject other values
# REQUEST_TIMEOUT=30         # seconds; bounds LLM calls
# DB_PATH=app/data/app.db
# CHROMA_PATH=app/data/chroma
# CORS_ORIGINS=http://localhost:3000
# PLACEHOLDER_USER_ID=dev-user   # legacy default; replaced by the authenticated user
